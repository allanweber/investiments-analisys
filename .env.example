# PostgreSQL (dev: docker compose up -d)

DATABASE_URL=postgresql://postgres:postgres@localhost:5434/investiments



# Better Auth — use a long random string in production

BETTER_AUTH_SECRET=replace-with-random-secret

BETTER_AUTH_URL=http://localhost:3001

# Production (Coolify / Dokploy): set public URL and origins, e.g.

# BETTER_AUTH_URL=https://invest.allanweber.dev

# BETTER_AUTH_TRUSTED_ORIGINS=https://invest.allanweber.dev,https://preview.example.com



# Optional: Google OAuth (omit to hide provider). In Google Cloud Console add
# authorized redirect URIs for production, e.g. https://invest.allanweber.dev/api/auth/callback/google

# GOOGLE_CLIENT_ID=

# GOOGLE_CLIENT_SECRET=

