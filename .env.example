# PostgreSQL (dev: docker compose up -d)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/investiments

# Better Auth — use a long random string in production
BETTER_AUTH_SECRET=replace-with-random-secret
BETTER_AUTH_URL=http://localhost:3001

# Optional: comma-separated extra origins (preview URLs, etc.)
# BETTER_AUTH_TRUSTED_ORIGINS=https://my-app.vercel.app

# Optional: Google OAuth (omit to hide provider)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
